  "customFishHelpIntro": "Overview",
  "customFishHelpIntroBody": "This screen allows you to edit custom sea creature parameters. Only common properties are supported; animation and special attributes require manual JSON editing.",
  "customFishHelpProps": "Properties",
  "customFishHelpPropsBody": "HitRect, AttackRect, ScareRect define collision areas. Speed and ScareSpeed control movement. ArtCenter defines center of the sprite.",
