  "barrelWaveTypeZombie": "Imp Barrel (barrelmoster)",
  "barrelWaveTypeExplosive": "Explosive Barrel (barrelpowder)",
  "barrelWaveRowsHint": "Rows are 1-based: Row 1 = top lane, Row 5/6 = bottom lane.",
